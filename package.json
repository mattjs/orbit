{
  "name": "orbit-monitor",
  "version": "0.1.0",
  "description": "Remote machine monitor via Slack bot",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orbit": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && cd web && npm run build",
    "build:server": "tsup",
    "build:web": "cd web && npm run build",
    "dev": "tsx src/index.ts",
    "dev:web": "cd web && npm run dev",
    "start": "node dist/index.js",
    "cli": "node dist/index.js --cli"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "@slack/bolt": "^4.1.0",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.12.5",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
